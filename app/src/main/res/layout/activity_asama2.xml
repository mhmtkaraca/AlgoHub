<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#E65100" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAsama2"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF8100"
        android:elevation="4dp"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Çalıştırmak istediğiniz sıralama algoritmasının rakamını seçiniz:"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="16dp" />

            <Button android:id="@+id/btnS1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1- Insertion Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2- Selection Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="3- Bubble Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="4- Divide and Conquer Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="5- Shell Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="6- Merge Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS7" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="7- Quick Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS8" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="8- Quick Sort3" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS9" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="9- Heap Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS10" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10- Radix Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS11" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="11- Shaker Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS12" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="12- Rastgele Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS13" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="13- Lucky Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS14" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="14- Stooge Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS15" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="15- Flash Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS16" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="16- Comb Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS17" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="17- Gnome Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS18" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="18- Permütasyon Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS19" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="19- Strand Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnS20" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="20- Kova Sort" android:textAllCaps="false" android:backgroundTint="#874200" android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
