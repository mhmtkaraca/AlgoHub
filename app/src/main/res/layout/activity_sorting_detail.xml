<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#E65100" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarSortDetail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF8100"
        android:elevation="4dp"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSortDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sıralama algoritması açıklaması"
                android:textSize="15sp"
                android:textColor="#444444"
                android:fontFamily="sans-serif"
                android:lineSpacingMultiplier="1.3"
                android:padding="10dp"
                android:background="#FFF3E0"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintTextColor="#FF8100"
                app:boxStrokeColor="#FF8100"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSortInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnSort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SIRALA"
                android:backgroundTint="#874200"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sıralanmamış Hali:"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="#555555"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvUnsorted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sıralanmış Hali:"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="#555555"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvSorted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#E65100"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#FFF3E0" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
